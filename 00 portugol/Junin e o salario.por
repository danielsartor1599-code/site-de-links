programa {
  funcao inicio() {
    real salario = 2000
    inteiro dias = 30
    real valorTotal
    inteiro semana = 5
    real salarioSemanal

    valorTotal = salario / dias
    escreva ("salario diario R$" + valorTotal)
    escreva("\n")
    salarioSemanal = valorTotal * semana
    escreva("já o salarioo semanal fica R$" + salarioSemanal)
    
  }
}
