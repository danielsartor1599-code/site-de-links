programa {
  funcao inicio() {
    inteiro idade
    cadeia nome = "Daniel"
    idade = 35
    // serve como lembrete/anotação dentro do programa e não aparece para o usuario!!
    escreva(nome)
   escreva ("\nminha idade é: ")
    escreva(idade)
    escreva("\n")
    idade = 45
  escreva("Ano que vem: " + idade)
  }
}
